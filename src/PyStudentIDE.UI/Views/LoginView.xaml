<UserControl
    x:Class="PyStudentIDE.UI.Views.LoginView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{DynamicResource WindowBackground}"
    Foreground="{DynamicResource PrimaryText}">
    <Grid>
        <!-- Login Panel -->
        <Border x:Name="LoginPanel" Width="380" HorizontalAlignment="Center" VerticalAlignment="Center"
                Style="{DynamicResource CardBorder}" Padding="32">
            <StackPanel>
                <TextBlock Text="PyStudentIDE" FontSize="28" FontWeight="Bold"
                           Foreground="{DynamicResource AccentBrush}" TextAlignment="Center"/>
                <TextBlock Text="Iniciar Sesión" FontSize="18" Foreground="{DynamicResource SecondaryText}"
                           Margin="0,4,0,24" TextAlignment="Center"/>

                <TextBlock Text="Correo institucional" FontSize="12" Foreground="{DynamicResource SecondaryText}" Margin="0,0,0,4"/>
                <TextBox x:Name="EmailBox" Style="{DynamicResource ModernTextBox}" Margin="0,0,0,12"/>

                <TextBlock Text="Contraseña" FontSize="12" Foreground="{DynamicResource SecondaryText}" Margin="0,0,0,4"/>
                <PasswordBox x:Name="PasswordBox" Style="{DynamicResource ModernPasswordBox}" Margin="0,0,0,4"/>

                <Button Content="Ingresar" Style="{DynamicResource PrimaryButton}" Margin="0,20,0,8" Click="OnLoginClick"/>
                <Button Content="Crear cuenta nueva" Style="{DynamicResource ModernButton}" Margin="0,0,0,8" Click="OnShowRegister"/>

                <TextBlock x:Name="ErrorText" Foreground="{DynamicResource ErrorBrush}" TextWrapping="Wrap"
                           Visibility="Collapsed" FontSize="12" TextAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Register Panel -->
        <Border x:Name="RegisterPanel" Width="380" HorizontalAlignment="Center" VerticalAlignment="Center"
                Style="{DynamicResource CardBorder}" Padding="32" Visibility="Collapsed">
            <StackPanel>
                <TextBlock Text="PyStudentIDE" FontSize="28" FontWeight="Bold"
                           Foreground="{DynamicResource AccentBrush}" TextAlignment="Center"/>
                <TextBlock Text="Crear Cuenta" FontSize="18" Foreground="{DynamicResource SecondaryText}"
                           Margin="0,4,0,24" TextAlignment="Center"/>

                <TextBlock Text="Nombre completo" FontSize="12" Foreground="{DynamicResource SecondaryText}" Margin="0,0,0,4"/>
                <TextBox x:Name="RegNameBox" Style="{DynamicResource ModernTextBox}" Margin="0,0,0,12"/>

                <TextBlock Text="Correo institucional" FontSize="12" Foreground="{DynamicResource SecondaryText}" Margin="0,0,0,4"/>
                <TextBox x:Name="RegEmailBox" Style="{DynamicResource ModernTextBox}" Margin="0,0,0,12"/>

                <TextBlock Text="Contraseña" FontSize="12" Foreground="{DynamicResource SecondaryText}" Margin="0,0,0,4"/>
                <PasswordBox x:Name="RegPasswordBox" Style="{DynamicResource ModernPasswordBox}" Margin="0,0,0,12"/>

                <TextBlock Text="Confirmar contraseña" FontSize="12" Foreground="{DynamicResource SecondaryText}" Margin="0,0,0,4"/>
                <PasswordBox x:Name="RegConfirmBox" Style="{DynamicResource ModernPasswordBox}" Margin="0,0,0,12"/>

                <TextBlock Text="Rol" FontSize="12" Foreground="{DynamicResource SecondaryText}" Margin="0,0,0,4"/>
                <ComboBox x:Name="RegRolBox" Style="{DynamicResource ModernComboBox}" Margin="0,0,0,4" SelectedIndex="0">
                    <ComboBoxItem Content="Estudiante" Tag="2"/>
                    <ComboBoxItem Content="Profesor" Tag="1"/>
                </ComboBox>

                <Button Content="Crear cuenta" Style="{DynamicResource PrimaryButton}" Margin="0,20,0,8" Click="OnRegisterClick"/>
                <Button Content="Volver a Iniciar Sesión" Style="{DynamicResource ModernButton}" Margin="0,0,0,8" Click="OnShowLogin"/>

                <TextBlock x:Name="RegErrorText" Foreground="{DynamicResource ErrorBrush}" TextWrapping="Wrap"
                           Visibility="Collapsed" FontSize="12" TextAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
