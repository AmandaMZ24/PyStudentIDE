<UserControl
    x:Class="PyStudentIDE.UI.Views.IdeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:PyStudentIDE.UI.Controls"
    Background="{DynamicResource WindowBackground}"
    Foreground="{DynamicResource PrimaryText}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="200"/>
        </Grid.RowDefinitions>

        <!-- Editor Panel -->
        <Grid Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Toolbar -->
            <Border Grid.Row="0" Background="{DynamicResource ToolbarBackground}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                <StackPanel Orientation="Horizontal" Margin="6,0">
                    <Button Content="📄 Nuevo" Style="{DynamicResource ModernButton}" Height="30" Margin="2,0" Click="OnNewFile"/>
                    <Button Content="📂 Abrir" Style="{DynamicResource ModernButton}" Height="30" Margin="2,0" Click="OnOpenFile"/>
                    <Button Content="💾 Guardar" Style="{DynamicResource ModernButton}" Height="30" Margin="2,0" Click="OnSaveFile"/>
                    <Button Content="🗑️ Borrar" Style="{DynamicResource DangerButton}" Height="30" Margin="2,0" Click="OnDeleteFile"/>

                    <Border Width="1" Height="20" Background="{DynamicResource BorderBrush}" Margin="6,0"/>

                    <Button Content="▶️ Ejecutar" Style="{DynamicResource ModernButton}" Height="30" Margin="2,0" Click="OnRun"/>
                    <Button Content="🧪 Pruebas" Style="{DynamicResource ModernButton}" Height="30" Margin="2,0" Click="OnRunTests"/>

                    <Border Width="1" Height="20" Background="{DynamicResource BorderBrush}" Margin="6,0"/>

                    <Button Content="🔏 Firmar" Style="{DynamicResource ModernButton}" Height="30" Margin="2,0" Click="OnSignScript"/>
                    <Button Content="✅ Verificar" Style="{DynamicResource ModernButton}" Height="30" Margin="2,0" Click="OnVerifyScript"/>

                    <Border Width="1" Height="20" Background="{DynamicResource BorderBrush}" Margin="6,0"/>

                    <TextBlock x:Name="ModeIndicator" Text="Listo" VerticalAlignment="Center"
                               Foreground="{DynamicResource SecondaryText}" FontSize="12" Margin="8,0"/>
                </StackPanel>
            </Border>

            <controls:PythonEditor x:Name="CodeEditor" Grid.Row="1"/>
        </Grid>

        <!-- Terminal Panel -->
        <Border Grid.Row="1" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
            <controls:TerminalControl x:Name="Terminal"/>
        </Border>
    </Grid>
</UserControl>
