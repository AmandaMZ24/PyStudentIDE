<UserControl
    x:Class="PyStudentIDE.UI.Views.TeacherPanelView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{DynamicResource WindowBackground}"
    Foreground="{DynamicResource PrimaryText}">
    <ScrollViewer>
        <Grid Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="Panel Docente" FontSize="26" FontWeight="Bold" />
                <TextBlock x:Name="TeacherName" FontSize="14" Foreground="{DynamicResource SecondaryText}" Margin="0,4,0,0" />
            </StackPanel>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="350" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Left: Courses list + Create -->
                <Border Grid.Column="0" Style="{DynamicResource CardBorder}" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Mis Cursos" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12" />

                        <ListBox x:Name="CoursesList" Style="{DynamicResource ModernListBox}"
                                 Height="200" DisplayMemberPath="Nombre"
                                 SelectionChanged="OnCourseSelected" />

                        <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,12" />

                        <TextBlock Text="Crear Nuevo Curso" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <TextBox x:Name="CourseCodeBox" Style="{DynamicResource ModernTextBox}"
                                 Margin="0,0,0,8" />
                        <TextBox x:Name="CourseNameBox" Style="{DynamicResource ModernTextBox}"
                                 Margin="0,0,0,8" />
                        <TextBox x:Name="CoursePeriodBox" Style="{DynamicResource ModernTextBox}"
                                 Text="2026-I" Margin="0,0,0,8" />
                        <Button Content="Crear Curso" Style="{DynamicResource PrimaryButton}"
                                Click="OnCreateCourse" />
                        <TextBlock x:Name="CourseError" Foreground="{DynamicResource ErrorBrush}"
                                   FontSize="12" TextWrapping="Wrap" Visibility="Collapsed" Margin="0,8,0,0" />
                    </StackPanel>
                </Border>

                <!-- Right: Course details -->
                <Border Grid.Column="1" Style="{DynamicResource CardBorder}">
                    <StackPanel>
                        <TextBlock x:Name="CourseTitle" FontSize="18" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryText}" />
                        <TextBlock x:Name="CourseInfo" FontSize="12"
                                   Foreground="{DynamicResource SecondaryText}" Margin="0,4,0,12" />

                        <TabControl Style="{DynamicResource ModernTabControl}" Height="Auto">
                            <!-- Assignments Tab -->
                            <TabItem Header="Asignaciones" Style="{DynamicResource ModernTabItem}">
                                <StackPanel>
                                    <ListBox x:Name="AssignmentsList" Style="{DynamicResource ModernListBox}"
                                             Height="120" DisplayMemberPath="Titulo"
                                             SelectionChanged="OnAssignmentSelected" />

                                    <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,8" />

                                    <TextBlock Text="Nueva Asignación" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6" />
                                    <TextBox x:Name="NewTitleBox" Style="{DynamicResource ModernTextBox}"
                                             Margin="0,0,0,6" />
                                    <TextBox x:Name="NewDescBox" Style="{DynamicResource ModernTextBox}"
                                             TextWrapping="Wrap" AcceptsReturn="True" Height="40" Margin="0,0,0,6" />
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Fecha límite:" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource SecondaryText}" FontSize="12" Margin="0,0,8,0" />
                                        <DatePicker x:Name="NewDeadlinePicker" Grid.Column="1" />
                                    </Grid>
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Inicio prueba:" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource SecondaryText}" FontSize="12" Margin="0,0,4,0" />
                                        <DatePicker x:Name="NewTestStartPicker" Grid.Column="1" Margin="0,0,8,0" />
                                        <TextBlock Grid.Column="2" Text="Fin prueba:" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource SecondaryText}" FontSize="12" Margin="0,0,4,0" />
                                        <DatePicker x:Name="NewTestEndPicker" Grid.Column="3" />
                                    </Grid>
                                    <Button Content="Crear Asignación" Style="{DynamicResource PrimaryButton}"
                                            Click="OnCreateAssignment" />
                                    <TextBlock x:Name="AssignmentError" Foreground="{DynamicResource ErrorBrush}"
                                               FontSize="12" TextWrapping="Wrap" Visibility="Collapsed" Margin="0,6,0,0" />
                                </StackPanel>
                            </TabItem>

                            <!-- Students Tab -->
                            <TabItem Header="Estudiantes" Style="{DynamicResource ModernTabItem}">
                                <StackPanel>
                                    <TextBlock x:Name="StudentCount" FontSize="12"
                                               Foreground="{DynamicResource SecondaryText}" Margin="0,0,0,8" />
                                    <ListBox x:Name="StudentsList" Style="{DynamicResource ModernListBox}"
                                             Height="250">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel>
                                                    <TextBlock FontWeight="SemiBold" Foreground="{DynamicResource PrimaryText}"
                                                               Text="{Binding Nombre}" />
                                                    <TextBlock FontSize="11" Foreground="{DynamicResource SecondaryText}"
                                                               Text="{Binding Correo}" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </StackPanel>
                            </TabItem>

                            <!-- Deliveries Tab -->
                            <TabItem Header="Entregas" Style="{DynamicResource ModernTabItem}">
                                <ScrollViewer>
                                    <StackPanel>
                                        <TextBlock x:Name="DeliveryInfo" FontSize="12"
                                                   Foreground="{DynamicResource SecondaryText}" Margin="0,0,0,8" />
                                        <ListBox x:Name="DeliveriesList" Style="{DynamicResource ModernListBox}"
                                                 Height="180" SelectionChanged="OnDeliverySelected">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock FontWeight="SemiBold" Foreground="{DynamicResource PrimaryText}"
                                                                   Text="{Binding EstudianteNombre}" />
                                                        <TextBlock Text=" - " Foreground="{DynamicResource SecondaryText}" />
                                                        <TextBlock Foreground="{DynamicResource SecondaryText}"
                                                                   Text="{Binding FechaEntrega, StringFormat=\{0:g\}}" />
                                                        <TextBlock Text=" | " Foreground="{DynamicResource SecondaryText}" />
                                                        <TextBlock Text="{Binding Estado}" Foreground="{DynamicResource SuccessBrush}" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                        <TextBlock x:Name="DeliveryDetail" FontSize="12"
                                                   Foreground="{DynamicResource SecondaryText}"
                                                   TextWrapping="Wrap" Margin="0,4,0,0" />
                                        <Button x:Name="ViewFileButton" Content="📄 Ver archivo entregado"
                                                Style="{DynamicResource ModernButton}" Height="26"
                                                Margin="0,4,0,0" Click="OnViewFile" Visibility="Collapsed"/>

                                        <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,8" />

                                        <TextBlock Text="Retroalimentación" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6" />
                                        <ListBox x:Name="FeedbackList" Style="{DynamicResource ModernListBox}"
                                                 Height="80" Margin="0,0,0,6">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel>
                                                        <TextBlock FontWeight="SemiBold" Foreground="{DynamicResource PrimaryText}"
                                                                   Text="{Binding NombreDocente}" />
                                                        <TextBlock FontSize="11" Foreground="{DynamicResource SecondaryText}"
                                                                   Text="{Binding Comentario}" TextWrapping="Wrap" />
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock FontSize="11" Foreground="{DynamicResource AccentBrush}"
                                                                       Text="{Binding Calificacion, StringFormat='Calificación: \{0:F1\}'}" />
                                                            <TextBlock FontSize="11" Foreground="{DynamicResource SecondaryText}"
                                                                       Text="{Binding FechaCreacion, StringFormat=' | \{0:g\}'}" />
                                                        </StackPanel>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>

                                        <TextBlock Text="Agregar Retroalimentación" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4" />
                                        <TextBox x:Name="FeedbackCommentBox" Style="{DynamicResource ModernTextBox}"
                                                 TextWrapping="Wrap" AcceptsReturn="True" Height="50" Margin="0,0,0,4" />
                                        <Grid Margin="0,0,0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Calificación:" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource SecondaryText}" FontSize="12" Margin="0,0,8,0" />
                                            <TextBox x:Name="FeedbackGradeBox" Grid.Column="1" Style="{DynamicResource ModernTextBox}"
                                                     Width="80" HorizontalAlignment="Left" />
                                            <Button Grid.Column="2" Content="Enviar Retroalimentación"
                                                    Style="{DynamicResource PrimaryButton}"
                                                    Click="OnSendFeedback" Margin="12,0,0,0" />
                                        </Grid>
                                        <TextBlock x:Name="FeedbackError" Foreground="{DynamicResource ErrorBrush}"
                                                   FontSize="12" TextWrapping="Wrap" Visibility="Collapsed" Margin="0,4,0,0" />
                                    </StackPanel>
                                </ScrollViewer>
                            </TabItem>
                            <!-- Keys Tab -->
                            <TabItem Header="Llaves" Style="{DynamicResource ModernTabItem}">
                                <StackPanel>
                                    <TextBlock Text="Gestión de Llaves Criptográficas" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8" />
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Content="🔑 Generar Llave"
                                                Style="{DynamicResource PrimaryButton}" Click="OnGenerateKey"
                                                Margin="0,0,6,0" />
                                        <Button Grid.Column="1" Content="❌ Desactivar Llave Activa"
                                                Style="{DynamicResource SidebarButton}" Click="OnDeactivateKey"
                                                Margin="6,0,0,0" />
                                    </Grid>
                                    <TextBlock x:Name="KeyStatus" FontSize="12"
                                               Foreground="{DynamicResource SecondaryText}"
                                               TextWrapping="Wrap" Margin="0,0,0,8" />
                                    <ListBox x:Name="ActiveKeyInfo" Style="{DynamicResource ModernListBox}"
                                             Height="80" Margin="0,0,0,4">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel>
                                                    <TextBlock FontWeight="SemiBold" Foreground="{DynamicResource PrimaryText}"
                                                               Text="{Binding Algoritmo}" />
                                                    <TextBlock FontSize="11" Foreground="{DynamicResource SecondaryText}"
                                                               Text="{Binding FechaCreacion, StringFormat='Creada: \{0:g\}'}" />
                                                    <TextBlock FontSize="11" Foreground="{DynamicResource SuccessBrush}"
                                                               Text="{Binding Activa, StringFormat='Activa: \{0\}'}" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </StackPanel>
                            </TabItem>
                        </TabControl>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
