<UserControl
    x:Class="PyStudentIDE.UI.Views.DashboardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="Dashboard" FontSize="22" FontWeight="Bold" Margin="0,0,0,20"/>
            <TextBlock Text="Cursos Activos" FontSize="16" FontWeight="SemiBold"/>
            <ListBox x:Name="CoursesList" Height="150" Margin="0,5,0,15"/>
            <TextBlock Text="Asignaciones Pendientes" FontSize="16" FontWeight="SemiBold"/>
            <ListBox x:Name="AssignmentsList" Height="200" Margin="0,5,0,15"/>
            <TextBlock x:Name="CountdownText" FontSize="14" Foreground="#E67E22"/>
        </StackPanel>
    </Grid>
</UserControl>
