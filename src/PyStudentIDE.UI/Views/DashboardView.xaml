<UserControl
    x:Class="PyStudentIDE.UI.Views.DashboardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{DynamicResource WindowBackground}"
    Foreground="{DynamicResource PrimaryText}">
    <ScrollViewer>
        <StackPanel Margin="28">
            <!-- Header -->
            <TextBlock Text="Dashboard" FontSize="26" FontWeight="Bold" Margin="0,0,0,24"/>

            <!-- Stats row -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Style="{DynamicResource CardBorder}" Margin="0,0,6,0">
                    <StackPanel>
                        <TextBlock Text="Cursos" FontSize="12" Foreground="{DynamicResource SecondaryText}" />
                        <TextBlock x:Name="CourseCount" FontSize="32" FontWeight="Bold"
                                   Foreground="{DynamicResource AccentBrush}" Text="0" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Style="{DynamicResource CardBorder}" Margin="6,0">
                    <StackPanel>
                        <TextBlock x:Name="Stat2Label" Text="Pendientes" FontSize="12" Foreground="{DynamicResource SecondaryText}" />
                        <TextBlock x:Name="PendingCount" FontSize="32" FontWeight="Bold"
                                   Foreground="{DynamicResource WarningBrush}" Text="0" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Style="{DynamicResource CardBorder}" Margin="6,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Estado" FontSize="12" Foreground="{DynamicResource SecondaryText}" />
                        <TextBlock x:Name="StatusText" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource SuccessBrush}" Text="Sin datos" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Teacher Section -->
            <StackPanel x:Name="TeacherSection" Visibility="Collapsed">
                <TextBlock Text="Resumen de Cursos" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <ListBox x:Name="DeliverySummaryList" Style="{DynamicResource ModernListBox}" Height="300" Margin="0,0,0,10">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{DynamicResource CardBorder}" Padding="10" Margin="0,0,0,6">
                                <StackPanel>
                                    <TextBlock Text="{Binding NombreCurso}" FontWeight="Bold"
                                               Foreground="{DynamicResource PrimaryText}" />
                                    <TextBlock FontSize="12" Foreground="{DynamicResource SecondaryText}">
                                        <Run Text="Asignaciones: " /><Run Text="{Binding TotalAsignaciones}" />
                                        <Run Text=" | Entregas: " /><Run Text="{Binding TotalEntregas}" />
                                        <Run Text=" | Estudiantes: " /><Run Text="{Binding TotalEstudiantes}" />
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>

            <!-- Student Section -->
            <StackPanel x:Name="StudentSection">
                <TextBlock Text="Cursos Activos" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <ListBox x:Name="CoursesList" Style="{DynamicResource ModernListBox}" Height="150" Margin="0,0,0,20"/>

                <TextBlock Text="Asignaciones Pendientes" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <ListBox x:Name="AssignmentsList" Style="{DynamicResource ModernListBox}" Height="200" Margin="0,0,0,10"/>

                <TextBlock x:Name="CountdownText" FontSize="13" Foreground="{DynamicResource WarningBrush}" Margin="0,0,0,10"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
