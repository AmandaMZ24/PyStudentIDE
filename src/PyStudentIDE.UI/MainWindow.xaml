<Window
    x:Class="PyStudentIDE.UI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="PyStudentIDE" Height="800" Width="1200"
    WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar Navigation -->
        <Border Grid.Column="0" Background="#2D2D2D">
            <StackPanel Margin="10">
                <TextBlock Text="PyStudentIDE" FontSize="20" Foreground="White" FontWeight="Bold" Margin="0,0,0,20"/>
                <Button Content="Dashboard" Margin="0,5" Height="40" Click="OnDashboardClick"/>
                <Button Content="Editor" Margin="0,5" Height="40" Click="OnEditorClick"/>
                <Button Content="Asignaciones" Margin="0,5" Height="40" Click="OnAssignmentsClick"/>
                <Button Content="Terminal" Margin="0,5" Height="40" Click="OnTerminalClick"/>
                <Button Content="Decorator" Margin="0,5" Height="40" Click="OnDecoratorClick"/>
                <Button Content="Cerrar Sesión" Margin="0,5" Height="40" Click="OnLogoutClick"/>
            </StackPanel>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Column="1">
            <ContentControl x:Name="MainContent" />
        </Grid>
    </Grid>
</Window>
