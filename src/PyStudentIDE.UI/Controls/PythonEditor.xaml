<UserControl
    x:Class="PyStudentIDE.UI.Controls.PythonEditor"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="0">
        <Grid>
            <TextBox
                x:Name="EditorTextBox"
                AcceptsReturn="True"
                AcceptsTab="True"
                FontFamily="Consolas"
                FontSize="14"
                TextWrapping="NoWrap"
                VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Auto"
                PreviewKeyDown="OnPreviewKeyDown"
                AllowDrop="False"
                Padding="14,10"
                Background="{DynamicResource EditorBackground}"
                Foreground="{DynamicResource PrimaryText}"
                BorderThickness="0"
                CaretBrush="{DynamicResource AccentBrush}"/>
        </Grid>
    </Border>
</UserControl>
