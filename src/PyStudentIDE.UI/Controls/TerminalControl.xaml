<UserControl
    x:Class="PyStudentIDE.UI.Controls.TerminalControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{DynamicResource TerminalBackground}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="32"/>
        </Grid.RowDefinitions>

        <!-- Terminal label + output -->
        <Grid Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Background="#2D2D2D" Padding="10,4">
                <TextBlock Text="Terminal" FontSize="11" Foreground="#8B949E"/>
            </Border>
            <TextBox
                x:Name="OutputBox"
                Grid.Row="1"
                Background="#1E1E1E"
                Foreground="#D4D4D4"
                FontFamily="Consolas"
                FontSize="12"
                IsReadOnly="True"
                VerticalScrollBarVisibility="Auto"
                TextWrapping="Wrap"
                Padding="10,6"
                BorderThickness="0"/>
        </Grid>

        <TextBox
            x:Name="InputBox"
            Grid.Row="1"
            Background="#2D2D2D"
            Foreground="#D4D4D4"
            FontFamily="Consolas"
            FontSize="12"
            BorderThickness="0"
            Padding="10,4"
            KeyDown="OnInputKeyDown"/>
    </Grid>
</UserControl>
